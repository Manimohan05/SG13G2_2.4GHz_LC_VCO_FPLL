** sch_path: /foss/designs/frac-n-pll-vco-unic_cass/schematic/top-pll/LC_VCO_PLL_op_tb.sch
**.subckt LC_VCO_PLL_op_tb OUTn CLK_OUT
*.opin OUTn
*.opin CLK_OUT
V1 VDD GND 1.2
I0 VDD net1 50u
Vfref CLK_IN GND 0 pulse(0 1.2 0n 0.1n 0.1n 5n 10n)
I1 net2 GND 10m
**** begin user architecture code



*****************************************************
* PLL + DSM Frequency Divider Testbench
*****************************************************

.option temp = 27
.param VDD = 1.2

* ==============================
* Include Models
